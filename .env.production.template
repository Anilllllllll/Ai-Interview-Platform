# ============================================
# Production Environment Variables Template
# ============================================
# Copy this to backend/.env.docker on your EC2 server
# Fill in your REAL production values
#
# SECURITY: Never commit this file to Git!
# This stays ONLY on your EC2 server.

PORT=5000

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
# Option A: Local MongoDB (Docker Compose)
# Use this when running MongoDB inside Docker Compose
MONGO_URI=mongodb://admin:CHANGE_THIS_STRONG_PASSWORD@mongo:27017/ai-interview?authSource=admin

# Option B: MongoDB Atlas (Cloud)
# Uncomment this and comment out Option A if using Atlas
# MONGO_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/ai-interview?retryWrites=true&w=majority

# ─────────────────────────────────────────
# AUTHENTICATION
# ─────────────────────────────────────────
# JWT_SECRET: Must be a long random string (64+ characters)
# Generate one: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

# ─────────────────────────────────────────
# AI API KEY
# ─────────────────────────────────────────
GROQ_API_KEY=your-production-groq-api-key

# ─────────────────────────────────────────
# GOOGLE OAUTH (Optional)
# ─────────────────────────────────────────
# Update the Google OAuth callback URL in Google Cloud Console
# to point to your EC2 domain/IP
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─────────────────────────────────────────
# FRONTEND URL (CORS)
# ─────────────────────────────────────────
# Set this to your EC2 public IP or domain name
# Examples:
#   http://54.123.45.67   (EC2 IP)
#   https://nexa.yourdomain.com (with domain + SSL)
FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP
