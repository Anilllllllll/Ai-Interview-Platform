# ============================================
# AI Interview App - Environment Variables
# ============================================
# Copy this file and rename to .env
# NEVER commit the actual .env file!

# ─────────────────────────────────────────
# Docker Compose Variables (project root .env)
# ─────────────────────────────────────────
# These are read by docker-compose.yml for the MongoDB container
MONGO_USERNAME=admin
MONGO_PASSWORD=your-strong-password-here

# ─────────────────────────────────────────
# Backend (backend/.env)
# ─────────────────────────────────────────
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ai-interview?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-change-this
GROQ_API_KEY=gsk_your-groq-api-key
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
FRONTEND_URL=http://localhost:5173
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────
# Frontend (frontend/.env)
# ─────────────────────────────────────────
VITE_API_URL=http://localhost:5000
